{
  "name": "helix-command",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prepare-sites.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
